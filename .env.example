# Whapi.Cloud (https://whapi.cloud) - token from your channel dashboard
WHAPI_TOKEN=your-whapi-token-here
WHAPI_BASE_URL=https://gate.whapi.cloud

# Authentication for translations is handled by claude-agent-sdk via your
# Claude Code login (Anthropic Max subscription). No API key needed here.

# Optional: shared secret to verify incoming webhooks (set in Whapi dashboard)
WEBHOOK_SECRET=

# Server
HOST=0.0.0.0
PORT=8000
